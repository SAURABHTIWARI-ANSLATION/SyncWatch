### Event Validation Rules

```javascript
// Server-side validation
function validateSyncEvent(event) {
  const validTypes = ['play', 'pause', 'seeked', 'ratechange'];
  
  if (!event.type || !validTypes.includes(event.type)) return false;
  if (typeof event.currentTime !== 'number' || event.currentTime < 0) return false;
  if (typeof event.playbackRate !== 'number' || event.playbackRate <= 0 || event.playbackRate > 16) return false;
  if (typeof event.element !== 'number' || event.element < 0) return false;
  if (typeof event.location !== 'string') return false;
  
  return true;
}

// Chat message validation  ← NEW
function validateChatMessage(text) {
  if (!text || typeof text !== 'string') return false;
  if (text.trim().length === 0) return false;
  if (text.length > 500) return false;   // max 500 chars
  return true;
}

// Chat history helper  ← NEW
const MAX_CHAT_HISTORY = 100;

function appendToHistory(roomName, messageObj) {
  const room = rooms[roomName];
  if (!room) return;
  room.chatHistory.push(messageObj);
  if (room.chatHistory.length > MAX_CHAT_HISTORY) {
    room.chatHistory.shift();   // remove oldest
  }
}
```

