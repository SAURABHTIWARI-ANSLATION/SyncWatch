    }, 100);
  });

  test('joining user receives chat history', (done) => {
    clientA.emit('join', { name: 'Alice', room: 'history-test' });
    
    setTimeout(() => {
      clientA.emit('chatMessage', { text: 'First message' });

      setTimeout(() => {
        clientB.emit('join', { name: 'Bob', room: 'history-test' });
        clientB.on('chatHistory', (data) => {
          expect(Array.isArray(data.messages)).toBe(true);
          expect(data.messages.some(m => m.text === 'First message')).toBe(true);
          done();
        });
      }, 100);
    }, 100);
  });

  test('system message posted on user join', (done) => {
