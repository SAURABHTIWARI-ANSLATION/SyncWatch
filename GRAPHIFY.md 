## 🔒 SECURITY & VALIDATION

### Input Validation

```javascript
// Name validation
function validateName(name) {
  if (!name || typeof name !== 'string') return false;
  if (name.length < 2 || name.length > 24) return false;
  if (!/^[a-zA-Z0-9_\s-]+$/.test(name)) return false;
  return true;
}

// Room name validation
function validateRoom(room) {
  if (!room || typeof room !== 'string') return false;
  if (room.length < 2 || room.length > 24) return false;
  if (!/^[a-zA-Z0-9_-]+$/.test(room)) return false;
  return true;
}

// URL validation (for shared videos)
function validateUrl(url) {
  try {
    const parsed = new URL(url);
    return ['http:', 'https:'].includes(parsed.protocol);
  } catch {
    return false;
  }
}

// Chat message validation  ← NEW
function validateChatMessage(text) {
  if (!text || typeof text !== 'string') return false;
  if (text.trim().length === 0) return false;
  if (text.length > 500) return false;
  return true;
}
```

### Rate Limiting

```javascript
const rateLimit = require('express-rate-limit');

const apiLimiter = rateLimit({
  windowMs: 15 * 60 * 1000,
  max: 100,
  message: 'Too many requests from this IP'
});
app.use('/api/', apiLimiter);

const socketRateLimiter = {
  maxEventsPerSecond: 10,
  violations: new Map()
};

function checkSocketRateLimit(socketId) {
  const now = Date.now();
  const violations = socketRateLimiter.violations;
  
  if (!violations.has(socketId)) {
    violations.set(socketId, { count: 1, timestamp: now });
    return true;
  }
  
  const record = violations.get(socketId);
  const elapsed = now - record.timestamp;
  
  if (elapsed > 1000) {
    violations.set(socketId, { count: 1, timestamp: now });
    return true;
  }
  
  if (record.count >= socketRateLimiter.maxEventsPerSecond) {
    return false;
  }
  
  record.count++;
  return true;
}
```

