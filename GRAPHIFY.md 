### Client-Side Usage (Extension)

```javascript
// Send a chat message
socket.emit('chatMessage', { text: "Ready to start the movie!" });

// Receive a chat message (any type)
socket.on('chatMessage', (msg) => {
  if (msg.type === 'system') {
    renderSystemMessage(msg.text, msg.timestamp);
  } else {
    renderUserMessage(msg.user, msg.text, msg.timestamp);
  }
});

// Receive history on room join
socket.on('chatHistory', (data) => {
  data.messages.forEach((msg) => {
    if (msg.type === 'system') {
      renderSystemMessage(msg.text, msg.timestamp);
    } else {
      renderUserMessage(msg.user, msg.text, msg.timestamp);
    }
  });
});

// Helper renderers
function renderUserMessage(user, text, timestamp) {
  const time = new Date(timestamp).toLocaleTimeString();
  chatContainer.insertAdjacentHTML('beforeend', `
    <div class="chat-msg">
      <span class="chat-user">${escapeHtml(user)}</span>
      <span class="chat-time">${time}</span>
      <p class="chat-text">${escapeHtml(text)}</p>
    </div>
  `);
  chatContainer.scrollTop = chatContainer.scrollHeight;
}

function renderSystemMessage(text, timestamp) {
  const time = new Date(timestamp).toLocaleTimeString();
  chatContainer.insertAdjacentHTML('beforeend', `
    <div class="chat-system">
      <span>${escapeHtml(text)}</span>
      <span class="chat-time">${time}</span>
    </div>
  `);
}

function escapeHtml(str) {
  return str.replace(/[&<>"']/g, (c) => ({
    '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;'
  }[c]));
}
```

